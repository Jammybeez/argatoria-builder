// Prisma schema for Better Auth
// learn more: https://better-auth.com/docs/concepts/database

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

// NOTE: When using mysql or sqlserver, uncomment the //@db.Text annotations in model Account below
// Further reading:
// https://www.prisma.io/docs/reference/api-reference/prisma-schema-reference#string

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id
  name          String //@db.Text
  email         String
  emailVerified Boolean   @default(false)
  image         String? //@db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt
  sessions      Session[]
  accounts      Account[]
  armies        Army[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String? //@db.Text
  userAgent String? //@db.Text
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String //@db.Text
  providerId            String //@db.Text
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String? //@db.Text
  refreshToken          String? //@db.Text
  idToken               String? //@db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String? //@db.Text
  password              String? //@db.Text
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String //@db.Text
  value      String //@db.Text
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@map("verification")
}

// ---------------------------------------------------------------------------
// Argatoria game data
// ---------------------------------------------------------------------------

enum UnitCategory {
  BASIC
  ELITE
  RARE
  UNIQUE
  HERO
}

// PER_BASE: pointsCost is multiplied by the number of bases/models chosen.
// FLAT: the unit is a single model at a fixed cost, quantity is always 1.
enum CostType {
  PER_BASE
  FLAT
}

// Sub-type for HERO-category units, used by army composition rules
// (min heroes, exactly-one-General, Command Group / Champion / Mage caps).
// Meaningless for non-HERO units, where it stays OTHER.
enum HeroType {
  GENERAL
  COMMAND_GROUP
  CHAMPION
  MAGE
  LEGENDARY_HERO
  OTHER
}

model Faction {
  id                  String @id @default(cuid())
  name                String @unique
  tagline             String?
  armySpecialRuleName String?
  armySpecialRuleText String?

  units  Unit[]
  armies Army[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Unit {
  id        String @id @default(cuid())
  factionId String
  faction   Faction @relation(fields: [factionId], references: [id], onDelete: Cascade)

  name       String
  category   UnitCategory
  costType   CostType
  pointsCost Int
  minBases   Int? // default/minimum bases per unit instance, for PER_BASE units
  maxBases   Int? // max bases per unit instance, for PER_BASE units
  heroType   HeroType @default(OTHER) // only meaningful when category is HERO

  // This unit can only be added to an army if a unit with this exact name is
  // already in the roster (e.g. Truhlaks (Skeletons) requires the General
  // "Lord Necromancer"; Larva of Nalharap requires the Mage "Black
  // Shepherd"). Not restricted to Generals. Null = no requirement.
  requiresHeroName String?

  // This unit's normal `category` is overridden to `recategorizeToCategory`
  // (for composition-rule counting and catalog/roster grouping) whenever a
  // GENERAL with name `recategorizeGeneralName` is in the roster, e.g. Horned
  // Warriors is normally ELITE but counts as BASIC under Lord of the Abyss.
  // The unit is still purchasable at its normal category otherwise.
  recategorizeGeneralName String?
  recategorizeToCategory  UnitCategory?

  // stat line
  ld Int?
  m  Int?
  ws Int?
  s  Int?
  t  Int?
  a  Int?
  w  Int?

  specialRules UnitSpecialRule[]
  armyUnits    ArmyUnit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([factionId])
}

model UnitSpecialRule {
  id     String @id @default(cuid())
  unitId String
  unit   Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)

  name String
  text String

  @@index([unitId])
}

model Army {
  id          String @id @default(cuid())
  name        String
  pointsLimit Int

  factionId String
  faction   Faction @relation(fields: [factionId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  units ArmyUnit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model ArmyUnit {
  id     String @id @default(cuid())
  armyId String
  army   Army   @relation(fields: [armyId], references: [id], onDelete: Cascade)

  unitId String
  unit   Unit   @relation(fields: [unitId], references: [id])

  quantity Int    @default(1)
  sortOrder Int   @default(0)

  upgrades ArmyUnitUpgrade[]

  createdAt DateTime @default(now())

  @@index([armyId])
}

// Banner / Spell / Magic Item / Artefact — bought for HERO-category units.
// Eligibility by hero sub-type: BANNER -> Command Group, SPELL & MAGIC_ITEM
// -> Mage, ARTEFACT -> General.
enum UpgradeType {
  BANNER
  SPELL
  MAGIC_ITEM
  ARTEFACT
}

model Upgrade {
  id         String      @id @default(cuid())
  type       UpgradeType
  name       String
  pointsCost Int

  // Spells only: casting range in cm, and the Magic Test target (D6 roll
  // must be <= this to succeed).
  range        Int?
  castingValue Int?

  // Null = usable by any faction. Some items are faction-locked (e.g. the
  // Sheol-morg-only Banner of God Seth).
  factionName String?

  // Free-text conditions too specific/bespoke to model structurally (e.g.
  // "Sheol-morg, General other than Lord Necromancer only"). Shown as a
  // caveat in the picker but not enforced.
  requirementsText String?
  effectText       String

  armyUnitUpgrades ArmyUnitUpgrade[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
}

model ArmyUnitUpgrade {
  id         String   @id @default(cuid())
  armyUnitId String
  armyUnit   ArmyUnit @relation(fields: [armyUnitId], references: [id], onDelete: Cascade)

  upgradeId String
  upgrade   Upgrade @relation(fields: [upgradeId], references: [id])

  createdAt DateTime @default(now())

  @@index([armyUnitId])
  @@index([upgradeId])
}
