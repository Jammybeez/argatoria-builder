// Prisma schema for Better Auth
// learn more: https://better-auth.com/docs/concepts/database

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

// NOTE: When using mysql or sqlserver, uncomment the //@db.Text annotations in model Account below
// Further reading:
// https://www.prisma.io/docs/reference/api-reference/prisma-schema-reference#string

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id
  name          String //@db.Text
  email         String
  emailVerified Boolean   @default(false)
  image         String? //@db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt
  sessions      Session[]
  accounts      Account[]
  armies        Army[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String? //@db.Text
  userAgent String? //@db.Text
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String //@db.Text
  providerId            String //@db.Text
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String? //@db.Text
  refreshToken          String? //@db.Text
  idToken               String? //@db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String? //@db.Text
  password              String? //@db.Text
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String //@db.Text
  value      String //@db.Text
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@map("verification")
}

// ---------------------------------------------------------------------------
// Argatoria game data
// ---------------------------------------------------------------------------

enum UnitCategory {
  BASIC
  ELITE
  RARE
  UNIQUE
  HERO
}

// PER_BASE: pointsCost is multiplied by the number of bases/models chosen.
// FLAT: the unit is a single model at a fixed cost, quantity is always 1.
enum CostType {
  PER_BASE
  FLAT
}

model Faction {
  id                  String @id @default(cuid())
  name                String @unique
  tagline             String?
  armySpecialRuleName String?
  armySpecialRuleText String?

  units  Unit[]
  armies Army[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Unit {
  id        String @id @default(cuid())
  factionId String
  faction   Faction @relation(fields: [factionId], references: [id], onDelete: Cascade)

  name       String
  category   UnitCategory
  costType   CostType
  pointsCost Int
  minBases   Int? // minimum bases/models per unit entry, if the unit has one
  isMage     Boolean @default(false)
  isGeneral  Boolean @default(false)

  // stat line
  ld Int?
  m  Int?
  ws Int?
  s  Int?
  t  Int?
  a  Int?
  w  Int?

  specialRules UnitSpecialRule[]
  armyUnits    ArmyUnit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([factionId])
}

model UnitSpecialRule {
  id     String @id @default(cuid())
  unitId String
  unit   Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)

  name String
  text String

  @@index([unitId])
}

model Army {
  id          String @id @default(cuid())
  name        String
  pointsLimit Int

  factionId String
  faction   Faction @relation(fields: [factionId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  units ArmyUnit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model ArmyUnit {
  id     String @id @default(cuid())
  armyId String
  army   Army   @relation(fields: [armyId], references: [id], onDelete: Cascade)

  unitId String
  unit   Unit   @relation(fields: [unitId], references: [id])

  quantity Int    @default(1)
  sortOrder Int   @default(0)

  createdAt DateTime @default(now())

  @@index([armyId])
}
